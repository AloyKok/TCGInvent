{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "destination": "/admin",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-yuyutei-market",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    }
  ]
}
